								"exec": [
									"pm.test('Status is 200', function () {",
									"    pm.response.to.have.status(200);",
									"});",
									"",
									"// Capture JSESSIONID from Set-Cookie header",
									"const cookie = pm.response.headers.filter(h => h.key === 'Set-Cookie')",
									"    .map(h => h.value)",
									"    .find(v => v.startsWith('JSESSIONID='));",
									"if (cookie) {",
									"    const sid = cookie.split(';')[0].split('=')[1];",
									"    pm.collectionVariables.set('jsessionid', sid);",
									"    console.log('Session saved: ' + sid.substring(0, 8) + '...');",
									"}"
								]
							}
