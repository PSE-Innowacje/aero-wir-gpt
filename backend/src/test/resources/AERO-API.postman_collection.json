						"body": {
							"mode": "raw",
							"raw": "{\n    \"registrationNumber\": \"SP-TST\",\n    \"type\": \"EC135\",\n    \"description\": \"Updated by flow\",\n    \"maxCrewCount\": 4,\n    \"maxCrewWeightKg\": 400,\n    \"status\": \"ACTIVE\",\n    \"inspectionExpiryDate\": \"2027-12-31\",\n    \"rangeKm\": 500\n}"
						},
						"url": { "raw": "{{baseUrl}}/api/helicopters/{{helicopterId}}", "host": ["{{baseUrl}}"], "path": ["api","helicopters","{{helicopterId}}"] }
					}
