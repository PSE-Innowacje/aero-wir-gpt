					"event": [
						{
							"listen": "test",
							"script": {
								"type": "text/javascript",
								"exec": [
									"pm.test('Status is 200', function () {",
									"    pm.response.to.have.status(200);",
									"});",
									"pm.test('Response is non-empty array', function () {",
									"    var json = pm.response.json();",
									"    pm.expect(json).to.be.an('array').that.is.not.empty;",
