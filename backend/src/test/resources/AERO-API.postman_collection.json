					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"name\": \"Radom EPRA\",\n    \"latitude\": 51.3892,\n    \"longitude\": 21.2133\n}"
						},
						"url": {
							"raw": "{{baseUrl}}/api/landing-sites",
							"host": ["{{baseUrl}}"],
							"path": ["api", "landing-sites"]
						}
					}
				},
				{
					"name": "Update Landing Site",
					"request": {
						"method": "PUT",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"name\": \"Babice EPBC (updated)\",\n    \"latitude\": 52.1850,\n    \"longitude\": 20.9115\n}"
						},
						"url": {
							"raw": "{{baseUrl}}/api/landing-sites/{{landingSiteId}}",
							"host": ["{{baseUrl}}"],
							"path": ["api", "landing-sites", "{{landingSiteId}}"]
						}
					}
				},
				{
					"name": "Create Landing Site (validation error)",
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
