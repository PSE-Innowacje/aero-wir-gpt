									"    var json = pm.response.json();",
									"    pm.collectionVariables.set('landingSiteId', json.id);",
									"}"
								]
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"name\": \"Babice EPBC\",\n    \"latitude\": 52.1847,\n    \"longitude\": 20.9111\n}"
						},
						"url": {
							"raw": "{{baseUrl}}/api/landing-sites",
