							"host": ["{{baseUrl}}"],
							"path": ["api", "landing-sites", "{{landingSiteId}}"]
						}
					}
				},
				{
					"name": "Create Landing Site (Babice EPBC)",
					"event": [
						{
							"listen": "test",
							"script": {
								"type": "text/javascript",
