							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"name\": \"\",\n    \"latitude\": null,\n    \"longitude\": null\n}"
						},
						"url": {
							"raw": "{{baseUrl}}/api/landing-sites",
							"host": ["{{baseUrl}}"],
							"path": ["api", "landing-sites"]
						},
						"description": "Should return 400 — blank name, null coordinates."
					}
				}
			]
		}
	]
}
