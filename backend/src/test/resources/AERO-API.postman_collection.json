{
	"info": {
		"name": "AERO API",
		"description": "AERO helicopter flight operations management API.\n\nSession-based auth (JSESSIONID cookie). Login first, then the cookie is automatically attached to subsequent requests.\n\nDefault users:\n- admin@aero.pl / admin (ADMIN)\n- planista@aero.pl / planista (PLANNER)\n- nadzor@aero.pl / nadzor (SUPERVISOR)\n- pilot@aero.pl / pilot (PILOT)",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
	},
	"variable": [
		{
			"key": "baseUrl",
			"value": "http://localhost:8080",
			"type": "string"
		},
		{
			"key": "jsessionid",
			"value": "",
			"type": "string"
		},
		{
			"key": "testEmail",
			"value": "",
			"type": "string"
		},
		{
			"key": "helicopterId",
			"value": "",
			"type": "string"
		},
		{
			"key": "landingSiteId",
			"value": "",
			"type": "string"
		}
	],
	"event": [
		{
			"listen": "prerequest",
			"script": {
				"type": "text/javascript",
				"exec": [
					"// Attach JSESSIONID cookie to every request if we have one",
					"const sid = pm.collectionVariables.get('jsessionid');",
					"if (sid) {",
					"    pm.request.headers.upsert({ key: 'Cookie', value: 'JSESSIONID=' + sid });",
					"}"
				]
			}
		}
	],
	"item": [
		{
			"name": "Test Flow (run with Collection Runner)",
			"description": "Sequential test suite — run all requests top-to-bottom via Collection Runner.\nGenerates a unique email per run so it is repeatable without clearing the DB.",
			"event": [
				{
					"listen": "prerequest",
					"script": {
						"type": "text/javascript",
						"exec": [
							"// Generate a unique test email once per run",
							"if (!pm.collectionVariables.get('testEmail')) {",
							"    const ts = Date.now();",
							"    pm.collectionVariables.set('testEmail', 'flow-' + ts + '@aero.pl');",
							"}"
						]
					}
				}
			],
			"item": [
				{
					"name": "1. Signup test ADMIN",
					"event": [
						{
							"listen": "test",
							"script": {
								"type": "text/javascript",
								"exec": [
									"pm.test('Signup returns 201', function () {",
									"    pm.response.to.have.status(201);",
									"});",
									"var json = pm.response.json();",
									"pm.test('Response has id and ADMIN role', function () {",
									"    pm.expect(json.id).to.be.a('string');",
									"    pm.expect(json.role).to.eql('ADMIN');",
									"    pm.expect(json.email).to.eql(pm.collectionVariables.get('testEmail'));",
									"});"
								]
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [{ "key": "Content-Type", "value": "application/json" }],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"firstName\": \"Flow\",\n    \"lastName\": \"Admin\",\n    \"email\": \"{{testEmail}}\",\n    \"password\": \"flow1234\",\n    \"role\": \"ADMIN\"\n}"
						},
						"url": { "raw": "{{baseUrl}}/api/auth/signup", "host": ["{{baseUrl}}"], "path": ["api","auth","signup"] }
					}
				},
				{
					"name": "2. Signup duplicate email → 400",
					"event": [
						{
							"listen": "test",
							"script": {
								"type": "text/javascript",
								"exec": [
									"pm.test('Duplicate email returns 400', function () {",
									"    pm.response.to.have.status(400);",
									"});",
									"pm.test('Error message mentions email', function () {",
									"    pm.expect(pm.response.json().message).to.include('Email');",
									"});"
								]
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [{ "key": "Content-Type", "value": "application/json" }],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"firstName\": \"Dup\",\n    \"lastName\": \"User\",\n    \"email\": \"{{testEmail}}\",\n    \"password\": \"flow1234\",\n    \"role\": \"PILOT\"\n}"
						},
						"url": { "raw": "{{baseUrl}}/api/auth/signup", "host": ["{{baseUrl}}"], "path": ["api","auth","signup"] }
					}
				},
				{
					"name": "3. Login as test ADMIN",
					"event": [
						{
							"listen": "test",
							"script": {
								"type": "text/javascript",
								"exec": [
									"pm.test('Login returns 200', function () {",
									"    pm.response.to.have.status(200);",
									"});",
									"pm.test('Role is ADMIN', function () {",
									"    pm.expect(pm.response.json().role).to.eql('ADMIN');",
									"});",
									"// Save session",
									"const cookie = pm.response.headers.filter(h => h.key === 'Set-Cookie')",
									"    .map(h => h.value).find(v => v.startsWith('JSESSIONID='));",
									"pm.test('Session cookie received', function () {",
									"    pm.expect(cookie).to.not.be.undefined;",
									"});",
									"if (cookie) {",
									"    pm.collectionVariables.set('jsessionid', cookie.split(';')[0].split('=')[1]);",
									"}"
								]
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [{ "key": "Content-Type", "value": "application/json" }],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"email\": \"{{testEmail}}\",\n    \"password\": \"flow1234\"\n}"
						},
						"url": { "raw": "{{baseUrl}}/api/auth/login", "host": ["{{baseUrl}}"], "path": ["api","auth","login"] }
					}
				},
				{
					"name": "4. Get /me → authenticated user",
					"event": [
						{
							"listen": "test",
							"script": {
								"type": "text/javascript",
								"exec": [
									"pm.test('Status is 200', function () {",
									"    pm.response.to.have.status(200);",
									"});",
									"pm.test('Returns current user email', function () {",
									"    pm.expect(pm.response.json().email).to.eql(pm.collectionVariables.get('testEmail'));",
									"});"
								]
							}
