							"raw": "{{baseUrl}}/api/landing-sites",
							"host": ["{{baseUrl}}"],
							"path": ["api", "landing-sites"]
						},
						"description": "Returns all landing sites sorted by name."
					}
				},
				{
					"name": "Get Landing Site by ID",
					"request": {
						"method": "GET",
						"header": [],
						"url": {
