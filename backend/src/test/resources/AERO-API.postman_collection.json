							"mode": "raw",
							"raw": "{\n    \"firstName\": \"Test\",\n    \"lastName\": \"User\",\n    \"email\": \"test@aero.pl\",\n    \"password\": \"test123\",\n    \"role\": \"ADMIN\"\n}"
						},
						"url": {
							"raw": "{{baseUrl}}/api/auth/signup",
							"host": ["{{baseUrl}}"],
							"path": ["api", "auth", "signup"]
						},
						"description": "Create a new user. No auth required. Roles: ADMIN, PLANNER, SUPERVISOR, PILOT."
